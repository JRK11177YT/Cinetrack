# ===============================
# CineTrack - Configuracion DEV (XAMPP local)
# ===============================
# Copia este fichero como  application-dev.properties  y rellena los valores.
# Ejecuta primero  scripts/setup-db.ps1  (Windows) o  scripts/setup-db.sh  (Linux/Mac)
# para crear la base de datos y el usuario dedicado.
#
# Activar en IntelliJ: Run > Edit Configurations > Environment Variables > SPRING_PROFILES_ACTIVE=dev
# Activar por terminal: $env:SPRING_PROFILES_ACTIVE="dev"; .\mvnw.cmd spring-boot:run

# ===============================
# BD local XAMPP
# ===============================
spring.datasource.url=jdbc:mysql://127.0.0.1:3306/cinetrack_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8&useUnicode=true
spring.datasource.username=cinetrack_user
spring.datasource.password=Cinetrack2024!

# ===============================
# JPA / Hibernate (dev: update para migraciones automaticas)
# ===============================
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# ===============================
# Thymeleaf (dev: sin cache para ver cambios al instante)
# ===============================
spring.thymeleaf.cache=false

# ===============================
# Remember-me key (dev: valor fijo para no perder la sesion en cada reinicio)
# ===============================
remember.me.key=cinetrack-dev-key-local
